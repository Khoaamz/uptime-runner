# Probe template — copy to `target-<N>.yml` and add the matching repo
# secrets. The YAML must NEVER contain a hostname or endpoint path
# directly — public-repo workflows are world-readable and the URL alone
# is a recon signal even when token-gated.
#
# Required repo secrets per target (e.g. for `target-2.yml`):
#   - TARGET_2_LIST_URL
#   - TARGET_2_REPORT_URL
#   - TARGET_2_TOKEN
#
# IMPORTANT: LIST_URL must be a READ-ONLY endpoint. If the list source
# also repairs the underlying resource, the monitor will self-heal the
# issue it's meant to detect.

name: target-N
on:
  schedule:
    - cron: '*/15 * * * *'
  workflow_dispatch: {}

jobs:
  probe:
    runs-on: ubuntu-latest
    timeout-minutes: 4
    steps:
      - uses: actions/checkout@v4

      - name: Probe
        env:
          TOKEN: ${{ secrets.TARGET_N_TOKEN }}
          LIST_URL: ${{ secrets.TARGET_N_LIST_URL }}
          REPORT_URL: ${{ secrets.TARGET_N_REPORT_URL }}
        run: |
          set -euo pipefail
          DOMAINS=$(curl -fsS \
            -H "X-Internal-Auth: $TOKEN" \
            "$LIST_URL" \
            | jq -r '.domains[] | .domain')
          if [ -z "$DOMAINS" ]; then
            echo "No targets. Nothing to probe."
            exit 0
          fi
          CHECKS=$(./lib/probe.sh $DOMAINS)
          curl -fsS -X POST \
            -H "X-Internal-Auth: $TOKEN" \
            -H "Content-Type: application/json" \
            -d "$(jq -n --argjson c "$CHECKS" '{checks: $c}')" \
            "$REPORT_URL"
